# Copy to .env (git-ignored) and fill in the two client values.
#
# One-time: enable the Drive API, then create an OAuth client ID of type
# "Desktop app" at https://console.cloud.google.com/apis/credentials and paste
# its ID + secret below. Then run `video-uploader auth` — it opens your browser
# and writes GOOGLE_REFRESH_TOKEN here automatically.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Drive folder replays are uploaded under (created if missing).
DRIVE_ROOT_FOLDER=NVIDIA Replays
