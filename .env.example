# Copy to .env and fill in. .env is git-ignored (holds secrets).
#
# From Google Cloud Console: enable the Drive API, create an OAuth client ID of
# type "Desktop app", and paste its client ID + secret below.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx

# Leave blank — `video-uploader auth` performs the consent flow and writes this
# back into .env for you.
GOOGLE_REFRESH_TOKEN=

# Drive folder that replays are uploaded under (created if missing).
DRIVE_ROOT_FOLDER=NVIDIA Replays
