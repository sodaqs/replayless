# Cargo build output — match `target/` at any depth (root + nested IDE/flycheck dirs)
target/

# Secrets — Google OAuth client id/secret + refresh token (commit .env.example)
.env

# Local, machine-specific config (commit config.example.toml instead)
config.toml

# Resumable pipeline state
manifest.json

# Transcoded output
/NVIDIA_compact/

# Quality-check / test artifacts (VMAF logs written with bare relative names)
vmaf_*.json

# Claude Code local runtime state (keep shared .claude/settings.json if added)
.claude/scheduled_tasks.lock
.claude/settings.local.json
